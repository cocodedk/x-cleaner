{
  "name": "x-cleaner",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "description": "Local Chromium-driven cleanup tool for your own X.com replies. No API tokens, no third-party server, no password automation.",
  "homepage": "https://cocodedk.github.io/x-cleaner/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cocodedk/x-cleaner.git"
  },
  "bugs": {
    "url": "https://github.com/cocodedk/x-cleaner/issues"
  },
  "author": "Babak Bandpey <bb@cocode.dk> (https://cocode.dk)",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "start": "tsx src/cli.ts",
    "login": "tsx src/cli.ts login",
    "probe": "tsx src/cli.ts probe",
    "run:cleaner": "tsx src/cli.ts run",
    "unlike": "tsx src/cli.ts unlike"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "playwright": "^1.61.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
